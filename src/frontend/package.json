{
  "name": "frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prelint": "svelte-kit sync",
    "lint": "eslint . --max-warnings=0",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --no-tsconfig",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --no-tsconfig --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretest:e2e": "svelte-kit sync",
    "test:e2e": "playwright test",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.49.0",
    "@storybook/addon-essentials": "^8.4.0",
    "@storybook/addon-interactions": "^8.4.0",
    "@storybook/addon-svelte-csf": "^5.1.2",
    "@storybook/addon-themes": "^8.4.0",
    "@storybook/svelte": "^8.4.0",
    "@storybook/sveltekit": "^8.4.0",
    "@storybook/test": "^8.4.0",
    "@sveltejs/adapter-node": "^5.2.0",
    "@sveltejs/kit": "^2.10.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/svelte": "^5.2.0",
    "@types/node": "^22.10.0",
    "@vitest/browser": "^2.1.0",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-svelte": "^2.46.0",
    "globals": "^15.13.0",
    "jsdom": "^25.0.0",
    "storybook": "^8.4.0",
    "svelte": "^5.14.0",
    "svelte-check": "^4.1.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.5"
  }
}
