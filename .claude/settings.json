{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "description": "sol-next1 agent guardrail harness. Hooks enforce SSOT/DRY, quality, and isolation.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [{ "type": "command", "command": "python3 .claude/hooks/session_start.py" }]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [{ "type": "command", "command": "python3 .claude/hooks/user_prompt_submit.py" }]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [{ "type": "command", "command": "python3 .claude/hooks/pre_tool_use_write.py" }]
      },
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "python3 .claude/hooks/pre_tool_use_bash.py" }]
      },
      {
        "matcher": "Read|Grep|Glob",
        "hooks": [{ "type": "command", "command": "python3 .claude/hooks/pre_tool_use_read.py" }]
      },
      {
        "matcher": "WebFetch|WebSearch",
        "hooks": [{ "type": "command", "command": "python3 .claude/hooks/pre_tool_use_web.py" }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [{ "type": "command", "command": "python3 .claude/hooks/post_tool_use_write.py" }]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(pnpm:*)",
      "Bash(uv:*)",
      "Bash(pytest:*)",
      "Bash(ruff:*)",
      "Bash(pyright:*)",
      "Bash(svelte-check:*)",
      "Bash(eslint:*)",
      "Bash(prettier:*)",
      "Bash(playwright:*)",
      "Bash(vitest:*)",
      "Bash(node:*)",
      "Bash(npx:*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git rev-parse:*)",
      "Bash(git remote:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)"
    ]
  }
}
